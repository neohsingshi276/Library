<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.secondhand.system.mapper.ProductMapper">

    <resultMap id="ProductResult" type="com.secondhand.system.domain.Product">
        <id property="productId" column="product_id"/>
        <result property="sellerId" column="seller_id"/>
        <result property="categoryId" column="category_id"/>
        <result property="title" column="title"/>
        <result property="description" column="description"/>
        <result property="brand" column="brand"/>
        <result property="size" column="size"/>
        <result property="conditionLevel" column="condition_level"/>
        <result property="originalPrice" column="original_price"/>
        <result property="salePrice" column="sale_price"/>
        <result property="donationAmount" column="donation_amount"/>
        <result property="donationRatio" column="donation_ratio"/>
        <result property="images" column="images"/>
        <result property="aiCheckStatus" column="ai_check_status"/>
        <result property="aiCheckResult" column="ai_check_result"/>
        <result property="aiCheckTime" column="ai_check_time"/>
        <result property="status" column="status"/>
        <result property="auditRemark" column="audit_remark"/>
        <result property="auditTime" column="audit_time"/>
        <result property="auditBy" column="audit_by"/>
        <result property="viewCount" column="view_count"/>
        <result property="favoriteCount" column="favorite_count"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="sellerName" column="seller_name"/>
        <result property="categoryName" column="category_name"/>
    </resultMap>

    <sql id="selectProductVo">
        select p.product_id, p.seller_id, p.category_id, p.title, p.description, p.brand, p.size, p.condition_level,
               p.original_price, p.sale_price, p.donation_amount, p.donation_ratio, p.images,
               p.ai_check_status, p.ai_check_result, p.ai_check_time, p.status, p.audit_remark,
               p.audit_time, p.audit_by, p.view_count, p.favorite_count, p.create_time, p.update_time,
               COALESCE(c.nick_name, c.user_name, '') as seller_name,
               COALESCE(pc.category_name, '') as category_name
        from product p
        left join client c on p.seller_id = c.user_id
        left join product_category pc on p.category_id = pc.category_id
    </sql>

    <select id="selectProductList" parameterType="com.secondhand.system.domain.Product" resultMap="ProductResult">
        <include refid="selectProductVo"/>
        <where>
            <if test="title != null and title != ''">and p.title like concat('%', #{title}, '%')</if>
            <if test="sellerId != null">and p.seller_id = #{sellerId}</if>
            <if test="categoryId != null and (categoryIds == null or categoryIds.length == 0)">and p.category_id = #{categoryId}</if>
            <if test="categoryIds != null and categoryIds.length > 0">
                and p.category_id in
                <foreach collection="categoryIds" item="id" open="(" separator="," close=")">
                    #{id}
                </foreach>
            </if>
            <if test="status != null and status != ''">and p.status = #{status}</if>
            <if test="aiCheckStatus != null and aiCheckStatus != ''">and p.ai_check_status = #{aiCheckStatus}</if>
            <if test="minPrice != null">and p.sale_price &gt;= #{minPrice}</if>
            <if test="maxPrice != null">and p.sale_price &lt;= #{maxPrice}</if>
        </where>
        <choose>
            <when test="orderBy != null and orderBy == 'sale_price'">
                <if test="order != null and order == 'asc'">
                    order by p.sale_price asc
                </if>
                <if test="order != null and order == 'desc'">
                    order by p.sale_price desc
                </if>
            </when>
            <otherwise>
                order by p.create_time desc
            </otherwise>
        </choose>
    </select>

    <select id="selectProductById" parameterType="Long" resultMap="ProductResult">
        <include refid="selectProductVo"/>
        where p.product_id = #{productId}
    </select>

    <insert id="insertProduct" parameterType="com.secondhand.system.domain.Product" useGeneratedKeys="true" keyProperty="productId">
        insert into product
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="sellerId != null">seller_id,</if>
            <if test="categoryId != null">category_id,</if>
            <if test="title != null">title,</if>
            <if test="description != null">description,</if>
            <if test="brand != null">brand,</if>
            <if test="size != null">size,</if>
            <if test="conditionLevel != null">condition_level,</if>
            <if test="originalPrice != null">original_price,</if>
            <if test="salePrice != null">sale_price,</if>
            <if test="donationAmount != null">donation_amount,</if>
            <if test="donationRatio != null">donation_ratio,</if>
            <if test="images != null">images,</if>
            <if test="aiCheckStatus != null">ai_check_status,</if>
            <if test="aiCheckResult != null">ai_check_result,</if>
            <if test="aiCheckTime != null">ai_check_time,</if>
            <if test="status != null">status,</if>
            <if test="auditRemark != null">audit_remark,</if>
            <if test="auditTime != null">audit_time,</if>
            <if test="auditBy != null">audit_by,</if>
            <if test="viewCount != null">view_count,</if>
            <if test="favoriteCount != null">favorite_count,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="sellerId != null">#{sellerId},</if>
            <if test="categoryId != null">#{categoryId},</if>
            <if test="title != null">#{title},</if>
            <if test="description != null">#{description},</if>
            <if test="brand != null">#{brand},</if>
            <if test="size != null">#{size},</if>
            <if test="conditionLevel != null">#{conditionLevel},</if>
            <if test="originalPrice != null">#{originalPrice},</if>
            <if test="salePrice != null">#{salePrice},</if>
            <if test="donationAmount != null">#{donationAmount},</if>
            <if test="donationRatio != null">#{donationRatio},</if>
            <if test="images != null">#{images},</if>
            <if test="aiCheckStatus != null">#{aiCheckStatus},</if>
            <if test="aiCheckResult != null">#{aiCheckResult},</if>
            <if test="aiCheckTime != null">#{aiCheckTime},</if>
            <if test="status != null">#{status},</if>
            <if test="auditRemark != null">#{auditRemark},</if>
            <if test="auditTime != null">#{auditTime},</if>
            <if test="auditBy != null">#{auditBy},</if>
            <if test="viewCount != null">#{viewCount},</if>
            <if test="favoriteCount != null">#{favoriteCount},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
        </trim>
    </insert>

    <update id="updateProduct" parameterType="com.secondhand.system.domain.Product">
        update product
        <trim prefix="set" suffixOverrides=",">
            <if test="sellerId != null">seller_id = #{sellerId},</if>
            <if test="categoryId != null">category_id = #{categoryId},</if>
            <if test="title != null">title = #{title},</if>
            <if test="description != null">description = #{description},</if>
            <if test="brand != null">brand = #{brand},</if>
            <if test="size != null">size = #{size},</if>
            <if test="conditionLevel != null">condition_level = #{conditionLevel},</if>
            <if test="originalPrice != null">original_price = #{originalPrice},</if>
            <if test="salePrice != null">sale_price = #{salePrice},</if>
            <if test="donationAmount != null">donation_amount = #{donationAmount},</if>
            <if test="donationRatio != null">donation_ratio = #{donationRatio},</if>
            <if test="images != null">images = #{images},</if>
            <if test="aiCheckStatus != null">ai_check_status = #{aiCheckStatus},</if>
            <if test="aiCheckResult != null">ai_check_result = #{aiCheckResult},</if>
            <if test="aiCheckTime != null">ai_check_time = #{aiCheckTime},</if>
            <if test="status != null">status = #{status},</if>
            <if test="auditRemark != null">audit_remark = #{auditRemark},</if>
            <if test="auditTime != null">audit_time = #{auditTime},</if>
            <if test="auditBy != null">audit_by = #{auditBy},</if>
            <if test="viewCount != null">view_count = #{viewCount},</if>
            <if test="favoriteCount != null">favorite_count = #{favoriteCount},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where product_id = #{productId}
    </update>

    <delete id="deleteProductByIds" parameterType="Long">
        delete from product where product_id in
        <foreach collection="array" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <delete id="deleteProductById" parameterType="Long">
        delete from product where product_id = #{productId}
    </delete>

    <!-- 统计商品总数 -->
    <select id="countAllProducts" resultType="Long">
        select count(*) from product
    </select>

    <!-- 统计今日新增商品 -->
    <select id="countTodayProducts" resultType="Long">
        select count(*) from product
        where date(create_time) = curdate()
    </select>

    <!-- 按状态统计商品数量 -->
    <select id="countProductsByStatus" resultType="map">
        select status, count(*) as count
        from product
        group by status
    </select>

</mapper>

