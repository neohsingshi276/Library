<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.secondhand.system.mapper.ProductOrderMapper">

    <resultMap id="ProductOrderResult" type="com.secondhand.system.domain.ProductOrder">
        <id property="orderId" column="order_id"/>
        <result property="orderNo" column="order_no"/>
        <result property="userId" column="user_id"/>
        <result property="productId" column="product_id"/>
        <result property="sellerId" column="seller_id"/>
        <result property="productTitle" column="product_title"/>
        <result property="productImage" column="product_image"/>
        <result property="salePrice" column="sale_price"/>
        <result property="originalPrice" column="original_price"/>
        <result property="orderAmount" column="order_amount"/>
        <result property="orderStatus" column="order_status"/>
        <result property="payStatus" column="pay_status"/>
        <result property="payTime" column="pay_time"/>
        <result property="payMethod" column="pay_method"/>
        <result property="payTransactionId" column="pay_transaction_id"/>
        <result property="shippingStatus" column="shipping_status"/>
        <result property="shippingTime" column="shipping_time"/>
        <result property="expressCompany" column="express_company"/>
        <result property="expressNo" column="express_no"/>
        <result property="receiverName" column="receiver_name"/>
        <result property="receiverPhone" column="receiver_phone"/>
        <result property="receiverProvince" column="receiver_province"/>
        <result property="receiverCity" column="receiver_city"/>
        <result property="receiverDistrict" column="receiver_district"/>
        <result property="receiverDetailAddress" column="receiver_detail_address"/>
        <result property="receiverPostalCode" column="receiver_postal_code"/>
        <result property="remark" column="remark"/>
        <result property="cancelReason" column="cancel_reason"/>
        <result property="cancelTime" column="cancel_time"/>
        <result property="completeTime" column="complete_time"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <sql id="selectProductOrderVo">
        select o.order_id, o.order_no, o.user_id, o.product_id, o.seller_id, o.product_title, o.product_image,
               o.sale_price, o.original_price, o.order_amount, o.order_status, o.pay_status, o.pay_time,
               o.pay_method, o.pay_transaction_id, o.shipping_status, o.shipping_time, o.express_company,
               o.express_no, o.receiver_name, o.receiver_phone, o.receiver_province, o.receiver_city,
               o.receiver_district, o.receiver_detail_address, o.receiver_postal_code, o.remark,
               o.cancel_reason, o.cancel_time, o.complete_time, o.create_time, o.update_time
        from product_order o
        left join product p on p.product_id = o.product_id
    </sql>

    <select id="selectProductOrderById" parameterType="Long" resultMap="ProductOrderResult">
        <include refid="selectProductOrderVo"/>
        where order_id = #{orderId}
    </select>

    <select id="selectProductOrderByOrderNo" parameterType="String" resultMap="ProductOrderResult">
        <include refid="selectProductOrderVo"/>
        where order_no = #{orderNo}
    </select>

    <select id="selectProductOrderList" parameterType="com.secondhand.system.domain.ProductOrder" resultMap="ProductOrderResult">
        <include refid="selectProductOrderVo"/>
        <where>
            <if test="orderNo != null and orderNo != ''">and o.order_no = #{orderNo}</if>
            <!-- 买家视角 -->
            <if test="userId != null and sellerId == null">and o.user_id = #{userId}</if>
            <!-- 卖家视角：通过商品表 seller_id 过滤 -->
            <if test="sellerId != null">and p.seller_id = #{sellerId}</if>
            <if test="productId != null">and o.product_id = #{productId}</if>
            <if test="orderStatus != null and orderStatus != ''">and o.order_status = #{orderStatus}</if>
            <if test="payStatus != null and payStatus != ''">and o.pay_status = #{payStatus}</if>
        </where>
        order by o.create_time desc
    </select>

    <insert id="insertProductOrder" parameterType="com.secondhand.system.domain.ProductOrder" useGeneratedKeys="true" keyProperty="orderId">
        insert into product_order
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="orderNo != null and orderNo != ''">order_no,</if>
            <if test="userId != null">user_id,</if>
            <if test="productId != null">product_id,</if>
            <if test="sellerId != null">seller_id,</if>
            <if test="productTitle != null">product_title,</if>
            <if test="productImage != null">product_image,</if>
            <if test="salePrice != null">sale_price,</if>
            <if test="originalPrice != null">original_price,</if>
            <if test="orderAmount != null">order_amount,</if>
            <if test="orderStatus != null">order_status,</if>
            <if test="payStatus != null">pay_status,</if>
            <if test="payTime != null">pay_time,</if>
            <if test="payMethod != null">pay_method,</if>
            <if test="payTransactionId != null">pay_transaction_id,</if>
            <if test="shippingStatus != null">shipping_status,</if>
            <if test="shippingTime != null">shipping_time,</if>
            <if test="expressCompany != null">express_company,</if>
            <if test="expressNo != null">express_no,</if>
            <if test="receiverName != null">receiver_name,</if>
            <if test="receiverPhone != null">receiver_phone,</if>
            <if test="receiverProvince != null">receiver_province,</if>
            <if test="receiverCity != null">receiver_city,</if>
            <if test="receiverDistrict != null">receiver_district,</if>
            <if test="receiverDetailAddress != null">receiver_detail_address,</if>
            <if test="receiverPostalCode != null">receiver_postal_code,</if>
            <if test="remark != null">remark,</if>
            <if test="cancelReason != null">cancel_reason,</if>
            <if test="cancelTime != null">cancel_time,</if>
            <if test="completeTime != null">complete_time,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="orderNo != null and orderNo != ''">#{orderNo},</if>
            <if test="userId != null">#{userId},</if>
            <if test="productId != null">#{productId},</if>
            <if test="sellerId != null">#{sellerId},</if>
            <if test="productTitle != null">#{productTitle},</if>
            <if test="productImage != null">#{productImage},</if>
            <if test="salePrice != null">#{salePrice},</if>
            <if test="originalPrice != null">#{originalPrice},</if>
            <if test="orderAmount != null">#{orderAmount},</if>
            <if test="orderStatus != null">#{orderStatus},</if>
            <if test="payStatus != null">#{payStatus},</if>
            <if test="payTime != null">#{payTime},</if>
            <if test="payMethod != null">#{payMethod},</if>
            <if test="payTransactionId != null">#{payTransactionId},</if>
            <if test="shippingStatus != null">#{shippingStatus},</if>
            <if test="shippingTime != null">#{shippingTime},</if>
            <if test="expressCompany != null">#{expressCompany},</if>
            <if test="expressNo != null">#{expressNo},</if>
            <if test="receiverName != null">#{receiverName},</if>
            <if test="receiverPhone != null">#{receiverPhone},</if>
            <if test="receiverProvince != null">#{receiverProvince},</if>
            <if test="receiverCity != null">#{receiverCity},</if>
            <if test="receiverDistrict != null">#{receiverDistrict},</if>
            <if test="receiverDetailAddress != null">#{receiverDetailAddress},</if>
            <if test="receiverPostalCode != null">#{receiverPostalCode},</if>
            <if test="remark != null">#{remark},</if>
            <if test="cancelReason != null">#{cancelReason},</if>
            <if test="cancelTime != null">#{cancelTime},</if>
            <if test="completeTime != null">#{completeTime},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
        </trim>
    </insert>

    <update id="updateProductOrder" parameterType="com.secondhand.system.domain.ProductOrder">
        update product_order
        <trim prefix="SET" suffixOverrides=",">
            <if test="orderStatus != null">order_status = #{orderStatus},</if>
            <if test="payStatus != null">pay_status = #{payStatus},</if>
            <if test="payTime != null">pay_time = #{payTime},</if>
            <if test="payMethod != null">pay_method = #{payMethod},</if>
            <if test="payTransactionId != null">pay_transaction_id = #{payTransactionId},</if>
            <if test="shippingStatus != null">shipping_status = #{shippingStatus},</if>
            <if test="shippingTime != null">shipping_time = #{shippingTime},</if>
            <if test="expressCompany != null">express_company = #{expressCompany},</if>
            <if test="expressNo != null">express_no = #{expressNo},</if>
            <if test="cancelReason != null">cancel_reason = #{cancelReason},</if>
            <if test="cancelTime != null">cancel_time = #{cancelTime},</if>
            <if test="completeTime != null">complete_time = #{completeTime},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where order_id = #{orderId}
    </update>

    <delete id="deleteProductOrderById" parameterType="Long">
        delete from product_order where order_id = #{orderId}
    </delete>

    <delete id="deleteProductOrderByIds" parameterType="String">
        delete from product_order where order_id in
        <foreach item="orderId" collection="array" open="(" separator="," close=")">
            #{orderId}
        </foreach>
    </delete>

    <!-- 统计订单总数 -->
    <select id="countAllOrders" resultType="Long">
        select count(*) from product_order
    </select>

    <!-- 统计今日新增订单 -->
    <select id="countTodayOrders" resultType="Long">
        select count(*) from product_order
        where date(create_time) = curdate()
    </select>

    <!-- 统计订单总金额 -->
    <select id="sumOrderAmount" resultType="java.math.BigDecimal">
        select COALESCE(sum(order_amount), 0) from product_order
        where pay_status = '1'
    </select>

    <!-- 获取最近30天的订单趋势 -->
    <select id="getOrderTrendLast30Days" resultType="map">
        select 
            date_format(create_time, '%m-%d') as date,
            count(*) as count,
            COALESCE(sum(case when pay_status = '1' then order_amount else 0 end), 0) as amount
        from product_order
        where create_time >= date_sub(curdate(), interval 30 day)
        group by date_format(create_time, '%Y-%m-%d'), date_format(create_time, '%m-%d')
        order by date_format(create_time, '%Y-%m-%d')
    </select>

    <!-- 获取最近12个月的交易金额统计 -->
    <select id="getMonthlyTransactionAmount" resultType="map">
        select 
            date_format(create_time, '%Y-%m') as month,
            COALESCE(sum(case when pay_status = '1' then order_amount else 0 end), 0) as amount
        from product_order
        where create_time >= date_sub(curdate(), interval 12 month)
        group by date_format(create_time, '%Y-%m')
        order by date_format(create_time, '%Y-%m')
    </select>

</mapper>

