<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.secondhand.system.mapper.ClientMapper">

	<resultMap type="Client" id="ClientResult">
		<result property="userId"    column="user_id"    />
		<result property="userName"    column="user_name"    />
		<result property="nickName"    column="nick_name"    />
		<result property="email"    column="email"    />
		<result property="phonenumber"    column="phonenumber"    />
		<result property="sex"    column="sex"    />
		<result property="avatar"    column="avatar"    />
		<result property="password"    column="password"    />
		<result property="status"    column="status"    />
		<result property="creditScore"    column="credit_score"    />
		<result property="totalDonation"    column="total_donation"    />
		<result property="totalAmount"    column="total_amount"    />
		<result property="totalOrders"    column="total_orders"    />
		<result property="createTime"    column="create_time"    />
		<result property="updateTime"    column="update_time"    />
		<result property="remark"    column="remark"    />
	</resultMap>

	<sql id="selectClientVo">
		select user_id, user_name, nick_name, email, phonenumber, sex, avatar, password, status, credit_score, total_donation, total_amount, total_orders, create_time, update_time, remark from client
	</sql>

	<select id="selectClientList" parameterType="Client" resultMap="ClientResult">
		<include refid="selectClientVo"/>
		<where>
			<if test="userName != null  and userName != ''"> and user_name like concat('%', #{userName}, '%')</if>
			<if test="nickName != null  and nickName != ''"> and nick_name like concat('%', #{nickName}, '%')</if>
			<if test="email != null  and email != ''"> and email = #{email}</if>
			<if test="phonenumber != null  and phonenumber != ''"> and phonenumber = #{phonenumber}</if>
			<if test="sex != null  and sex != ''"> and sex = #{sex}</if>
			<if test="avatar != null  and avatar != ''"> and avatar = #{avatar}</if>
			<if test="password != null  and password != ''"> and password = #{password}</if>
			<if test="status != null  and status != ''"> and status = #{status}</if>
		</where>
	</select>

	<select id="selectUserByUserName" resultType="com.secondhand.common.core.domain.entity.Client">
		<include refid="selectClientVo"/>
		where user_name = #{userName}
	</select>

	<select id="selectUserById" resultType="com.secondhand.common.core.domain.entity.Client">
		<include refid="selectClientVo"/>
		where user_id = #{userId}
	</select>

	<select id="checkPhoneUnique" resultType="com.secondhand.common.core.domain.entity.Client">
		<include refid="selectClientVo"/>
		where phonenumber = #{phonenumber}
	</select>

	<select id="checkUserNameUnique" resultType="com.secondhand.common.core.domain.entity.Client">
		<include refid="selectClientVo"/>
		where user_name = #{userName}
	</select>

	<select id="checkEmailUnique" resultType="com.secondhand.common.core.domain.entity.Client">
		<include refid="selectClientVo"/>
		where email = #{email}
	</select>

    <select id="checkNameUnique" resultType="com.secondhand.common.core.domain.entity.Client">
		<include refid="selectClientVo"/>
		where nick_name = #{nickName}
	</select>

    <insert id="insertClient" parameterType="Client" useGeneratedKeys="true" keyProperty="userId">
		insert into client
		<trim prefix="(" suffix=")" suffixOverrides=",">
			<if test="userName != null and userName != ''">user_name,</if>
			<if test="nickName != null and nickName != ''">nick_name,</if>
			<if test="email != null">email,</if>
			<if test="phonenumber != null">phonenumber,</if>
			<if test="sex != null">sex,</if>
			<if test="avatar != null">avatar,</if>
			<if test="password != null">password,</if>
			<if test="status != null">status,</if>
			<if test="createTime != null">create_time,</if>
			<if test="updateTime != null">update_time,</if>
			<if test="remark != null">remark,</if>
		</trim>
		<trim prefix="values (" suffix=")" suffixOverrides=",">
			<if test="userName != null and userName != ''">#{userName},</if>
			<if test="nickName != null and nickName != ''">#{nickName},</if>
			<if test="email != null">#{email},</if>
			<if test="phonenumber != null">#{phonenumber},</if>
			<if test="sex != null">#{sex},</if>
			<if test="avatar != null">#{avatar},</if>
			<if test="password != null">#{password},</if>
			<if test="status != null">#{status},</if>
			<if test="createTime != null">#{createTime},</if>
			<if test="updateTime != null">#{updateTime},</if>
			<if test="remark != null">#{remark},</if>
		</trim>
	</insert>

	<update id="updateClient" parameterType="Client">
		update client
		<trim prefix="SET" suffixOverrides=",">
			<if test="userName != null and userName != ''">user_name = #{userName},</if>
			<if test="nickName != null and nickName != ''">nick_name = #{nickName},</if>
			<if test="email != null">email = #{email},</if>
			<if test="phonenumber != null">phonenumber = #{phonenumber},</if>
			<if test="sex != null">sex = #{sex},</if>
			<if test="avatar != null">avatar = #{avatar},</if>
			<if test="password != null">password = #{password},</if>
			<if test="status != null">status = #{status},</if>
			<if test="createTime != null">create_time = #{createTime},</if>
			<if test="updateTime != null">update_time = #{updateTime},</if>
			<if test="remark != null">remark = #{remark},</if>
		</trim>
		where user_id = #{userId}
	</update>

	<update id="resetUserPwd">
		update client set password = #{password} where user_name = #{userName}
	</update>

	<update id="updateUserAvatar">
		update client set avatar = #{avatar} where user_name = #{userName}
	</update>

	<update id="updateCreditScore">
		update client set credit_score = #{creditScore}, update_time = now() where user_id = #{userId}
	</update>

	<update id="increaseCreditScore">
		update client set credit_score = IFNULL(credit_score, 100) + #{points}, update_time = now() where user_id = #{userId}
	</update>

	<update id="decreaseCreditScore">
		update client set credit_score = GREATEST(IFNULL(credit_score, 100) - #{points}, 0), update_time = now() where user_id = #{userId}
	</update>

	<update id="increaseTotalAmount">
		update client set total_amount = IFNULL(total_amount, 0) + #{amount}, update_time = now() where user_id = #{userId}
	</update>

	<update id="increaseTotalOrders">
		update client set total_orders = IFNULL(total_orders, 0) + 1, update_time = now() where user_id = #{userId}
	</update>

	<delete id="deleteClientByUserId" parameterType="Long">
		delete from client where user_id = #{userId}
	</delete>

	<delete id="deleteClientByUserIds" parameterType="String">
		delete from client where user_id in
		<foreach item="userId" collection="array" open="(" separator="," close=")">
			#{userId}
		</foreach>
	</delete>

	<!-- 统计用户总数 -->
	<select id="countAllClients" resultType="Long">
		select count(*) from client
	</select>

	<!-- 统计今日新增用户 -->
	<select id="countTodayClients" resultType="Long">
		select count(*) from client
		where date(create_time) = curdate()
	</select>

	<!-- 统计本月新增用户 -->
	<select id="countThisMonthClients" resultType="Long">
		select count(*) from client
		where date_format(create_time, '%Y-%m') = date_format(curdate(), '%Y-%m')
	</select>

	<!-- 统计上月新增用户 -->
	<select id="countLastMonthClients" resultType="Long">
		select count(*) from client
		where date_format(create_time, '%Y-%m') = date_format(date_sub(curdate(), interval 1 month), '%Y-%m')
	</select>

	<!-- 获取最近7天的用户增长趋势 -->
	<select id="getDailyUserGrowth" resultType="map">
		select 
			date_format(create_time, '%m-%d') as date,
			count(*) as count
		from client
		where create_time >= date_sub(curdate(), interval 7 day)
		group by date_format(create_time, '%Y-%m-%d'), date_format(create_time, '%m-%d')
		order by date_format(create_time, '%Y-%m-%d')
	</select>

</mapper>
